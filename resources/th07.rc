// Resource script for th07e.exe.
//
// Embeds the game icon (placeholder until the binary-match build extracts the
// original). Mirrors the th06 resource layout.
#include <windows.h>

// ICON_RESOURCE is the icon group the loader shows for the exe / taskbar.
// The icon is built into build/icon.ico by configure.py; reference it via the
// build-relative path so rc.exe (invoked from the repo root) can find it.
ICON_RESOURCE ICON "build/icon.ico"

// Standard version-info block. Values intentionally neutral; the real exe
// ships a Microsoft-annotated VS_VERSION_INFO that we will reproduce when
// the binary-match build lands.
VS_VERSION_INFO VERSIONINFO
FILEVERSION    0,0,0,0
PRODUCTVERSION 0,0,0,0
FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
FILEFLAGS      0
FILEOS         VOS_NT_WINDOWS32
FILETYPE       VFT_APP
FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "041104b0"
        BEGIN
            VALUE "CompanyName",      "\0"
            VALUE "FileDescription",  "th07\0"
            VALUE "FileVersion",      "0,0,0,0\0"
            VALUE "InternalName",     "th07\0"
            VALUE "OriginalFilename", "th07e.exe\0"
            VALUE "ProductName",      "th07\0"
            VALUE "ProductVersion",   "0,0,0,0\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x411, 1200
    END
END
